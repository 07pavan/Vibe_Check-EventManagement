# ============================================================
# GoAttend — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in real values for local dev.
# For Render production, set these in the Render dashboard:
#   Dashboard → Your Service → Environment → Add Environment Variable
#
# DO NOT commit .env to git — it is in .gitignore.
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Set to False in production. Render sets this automatically
# via render.yaml (DEBUG=False).
DEBUG=True

# Comma-separated. In production: your-app.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────
# Leave empty to use SQLite locally.
# Production (Neon.tech): paste your full connection string.
# Format: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Cloudinary (Media Storage) ────────────────────────────────
# Leave empty to store uploads locally in media/ folder.
# Production: get this from Cloudinary Dashboard → API Keys.
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# ── CORS / CSRF ───────────────────────────────────────────────
# Your Vercel frontend URL(s) — comma-separated, no trailing slash.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# For production, add your Render backend URL too:
# CORS_ALLOWED_ORIGINS=https://go-attend.vercel.app,https://eventmanagement-api1.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend (config.js) ─────────────────────────────────────
# This is NOT used by Django — it drives the Vercel buildCommand.
# Vercel reads RENDER_API_URL and auto-generates frontend/config.js at build time.
# Local:      window.GOATTEND_API = 'http://127.0.0.1:8001/api'
# Production: window.GOATTEND_API = 'https://eventmanagement-api1.onrender.com/api'
RENDER_API_URL=https://your-render-service.onrender.com
